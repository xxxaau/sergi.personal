{{- $pctx := . -}}
{{- if .IsHome -}}
  {{- $pctx = .Site -}}
{{- end -}}
{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0"
  xmlns:atom="http://www.w3.org/2005/Atom"
  xmlns:content="http://purl.org/rss/1.0/modules/content/"
  xmlns:dc="http://purl.org/dc/elements/1.1/">
  <channel>
    <title>{{ if eq .Title .Site.Title }}{{ .Site.Title }}{{ else }}{{ .Title }} - {{ .Site.Title }}{{ end }}</title>
    <link>{{ .Permalink }}</link>
    <description>{{ with .Description }}{{ . }}{{ else }}{{ .Site.Params.description }}{{ end }}</description>
    <generator>Hugo -- gohugo.io</generator>
    <language>{{ .Site.LanguageCode }}</language>
    <lastBuildDate>{{ now.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</lastBuildDate>
    {{- with .OutputFormats.Get "RSS" }}
    <atom:link href="{{ .Permalink }}" rel="self" type="{{ .MediaType.Type }}" />
    {{- end }}

    {{- range first 20 $pctx.RegularPages }}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <guid isPermaLink="true">{{ .Permalink }}</guid>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
      {{- with .Params.author }}<dc:creator>{{ . }}</dc:creator>{{ end }}

      {{- $description := .Summary | plainify -}}
      {{- with .Description -}}
        {{- $description = . -}}
      {{- end -}}
      {{- $description = $description | htmlUnescape | replaceRE `\s+` " " | trim -}}
      <description>{{ $description }}</description>

      {{- $content := .Content -}}
      {{- $content = replaceRE `(?is)<video[\s\S]*?</video>` "" $content -}}
      {{- $content = $content | htmlUnescape -}}
      {{- $content = replace $content "]]>" "]]]]><![CDATA[>" -}}
      <content:encoded>{{ printf "<![CDATA[%s]]>" $content | safeHTML }}</content:encoded>
    </item>
    {{- end }}
  </channel>
</rss>